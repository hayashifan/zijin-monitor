# 紫金单股监控器 - 环境变量配置
# 复制此文件为 .env 并根据需要修改

# 后端服务端口
PORT=3001

# SQLite 数据库路径 (相对于 backend 目录)
DATABASE_PATH=../data/zijin_monitor.db

# CORS 允许的前端地址
CORS_ORIGIN=http://localhost:5173

# 新浪财经 API 超时时间 (秒)
SINA_API_TIMEOUT=10

# 缓存 TTL (秒) - 行情数据缓存时间
CACHE_TTL_SECONDS=300

# 监控的股票代码 (格式: A:代码,HK:代码)
STOCK_CODES=A:601899,HK:02899

# 是否绕过系统代理 (Windows 可能需要)
BYPASS_SYSTEM_PROXY=True
